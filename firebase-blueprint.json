{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A restaurant order, either for a table or delivery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tableId": { "type": "string" },
        "tableName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "cost": { "type": "number" },
              "quantity": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["PENDING", "PREPARING", "READY", "DELIVERED", "CANCELLED", "FINISHED"] },
        "paymentStatus": { "type": "string", "enum": ["PENDING", "PAID", "FAILED"] },
        "subtotal": { "type": "number" },
        "serviceFee": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "total": { "type": "number" },
        "type": { "type": "string", "enum": ["TABLE", "DELIVERY"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "waiterId": { "type": "string" },
        "waiterName": { "type": "string" },
        "peopleCount": { "type": "number" },
        "cashierSessionId": { "type": "string" },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "amount": { "type": "number" },
              "method": { "type": "string", "enum": ["CASH", "CARD", "PIX"] },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["items", "status", "paymentStatus", "subtotal", "total", "type", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A menu item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "available": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "barcode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "available"]
    },
    "Table": {
      "title": "Table",
      "description": "A restaurant table.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "status": { "type": "string", "enum": ["AVAILABLE", "OCCUPIED", "RESERVED"] },
        "capacity": { "type": "number" },
        "currentOrderId": { "type": "string" }
      },
      "required": ["number", "status", "capacity"]
    },
    "Waiter": {
      "title": "Waiter",
      "description": "A staff member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "active"]
    },
    "RestaurantSettings": {
      "title": "RestaurantSettings",
      "description": "Global settings for the restaurant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurantName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "serviceFee": { "type": "number" },
        "operatingHours": {
          "type": "object",
          "properties": {
            "open": { "type": "string" },
            "close": { "type": "string" }
          }
        },
        "happyHour": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "start": { "type": "string" },
            "end": { "type": "string" },
            "discount": { "type": "number" }
          }
        },
        "whatsappNumber": { "type": "string" }
      },
      "required": ["restaurantName", "serviceFee"]
    },
    "CashierSession": {
      "title": "CashierSession",
      "description": "A cashier opening/closing session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "openedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "openedBy": { "type": "string" },
        "closedBy": { "type": "string" },
        "openingBalance": { "type": "number" },
        "closingBalancePhysical": { "type": "number" },
        "closingBalanceSystem": { "type": "number" },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"] }
      },
      "required": ["openedAt", "openedBy", "openingBalance", "status"]
    },
    "User": {
      "title": "User",
      "description": "A system user with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of system users and their roles."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all orders."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all menu items."
    },
    "/tables/{tableId}": {
      "schema": "Table",
      "description": "Collection of all tables."
    },
    "/waiters/{waiterId}": {
      "schema": "Waiter",
      "description": "Collection of all waiters."
    },
    "/settings/{settingsId}": {
      "schema": "RestaurantSettings",
      "description": "Global settings document."
    },
    "/cashierSessions/{sessionId}": {
      "schema": "CashierSession",
      "description": "Collection of cashier sessions."
    }
  }
}
