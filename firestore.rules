rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Modelo de Dados Assumido (Documentação)
    // ===============================================================
    //
    // Coleção: orders (Pedidos)
    // Campos: items, status, paymentStatus, subtotal, total, type, createdAt, updatedAt, ...
    //
    // Coleção: products (Produtos)
    // Campos: name, price, category, available, cost, barcode, imageUrl, ...
    //
    // Coleção: tables (Mesas)
    // Campos: number, status, capacity, currentOrderId
    //
    // Coleção: waiters (Garçons)
    // Campos: name, phone, active
    //
    // Coleção: settings (Configurações)
    // Campos: restaurantName, address, phone, serviceFee, ...
    //
    // Coleção: cashier_sessions (Turnos de Caixa)
    // Campos: openedAt, closedAt, openedBy, closedBy, openingBalance, closingBalancePhysical, closingBalanceSystem, status
    //
    // Coleção: allowed_emails (E-mails autorizados)
    // Campos: email, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Funções Auxiliares de Segurança
    // ===============================================================
    
    // Verifica se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o usuário logado é um Administrador
    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "gustavosadoque19@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Verifica se o usuário logado é um Gerente ou Administrador
    function isManager() {
      return isAuthenticated() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager'));
    }

    // Valida se todos os campos obrigatórios estão presentes na requisição
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Garante que apenas os campos permitidos estão sendo enviados
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // --- Validadores de Domínio (Garantem a integridade dos dados) ---

    // Validação para criação/edição de Produtos
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.available is bool &&
             data.stock is number &&
             (!('ncm' in data) || data.ncm is string) &&
             (!('cest' in data) || data.cest is string) &&
             (!('cfop' in data) || data.cfop is string) &&
             (!('icmsOrigin' in data) || data.icmsOrigin is string) &&
             (!('icmsSituation' in data) || data.icmsSituation is string);
    }

    // Validação para criação/edição de Pedidos
    function isValidOrder(data) {
      return data.items is list &&
             data.status in ['PENDING', 'PREPARING', 'DELIVERING', 'FINISHED', 'CANCELLED', 'READY'] &&
             data.subtotal is number &&
             data.total is number &&
             data.type in ['TABLE', 'DELIVERY', 'PICKUP'] &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp) &&
             (!('isPickup' in data) || data.isPickup is bool) &&
             (!('locationUrl' in data) || data.locationUrl == null || data.locationUrl is string) &&
             (!('tableId' in data) || data.tableId == null || data.tableId is string) &&
             (!('waiterId' in data) || data.waiterId == null || data.waiterId is string) &&
             (!('customerName' in data) || data.customerName == null || data.customerName is string) &&
             (!('customerPhone' in data) || data.customerPhone == null || data.customerPhone is string) &&
             (!('customerDocument' in data) || data.customerDocument == null || data.customerDocument is string) &&
             (!('deliveryAddress' in data) || data.deliveryAddress == null || data.deliveryAddress is string) &&
             (!('invoiceEmitted' in data) || data.invoiceEmitted is bool) &&
             (!('invoiceUrl' in data) || data.invoiceUrl is string) &&
             (!('serviceFee' in data) || data.serviceFee is number) &&
             (!('deliveryFee' in data) || data.deliveryFee is number) &&
             (!('payments' in data) || data.payments is list) &&
             (!('peopleCount' in data) || data.peopleCount is number) &&
             (!('platform' in data) || data.platform == null || data.platform is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // Validação para Mesas
    function isValidTable(data) {
      return data.number is number &&
             data.status in ['Livre', 'Ocupada', 'Aguardando Limpeza', 'Fechando Conta'];
    }

    // Validação para Garçons
    function isValidWaiter(data) {
      return data.name is string && data.name.size() > 0;
    }

    // Validação para Configurações do Sistema
    function isValidSettings(data) {
      return (!('restaurantName' in data) || (data.restaurantName is string && data.restaurantName.size() > 0 && data.restaurantName.size() < 100)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('whatsappNumber' in data) || (data.whatsappNumber is string && data.whatsappNumber.size() < 20)) &&
             (!('CNPJ' in data) || (data.CNPJ is string && data.CNPJ.size() < 20)) &&
             (!('IE' in data) || (data.IE is string && data.IE.size() < 20)) &&
             (!('serviceFee' in data) || (data.serviceFee is number && data.serviceFee >= 0)) &&
             (!('blockSaleNoStock' in data) || data.blockSaleNoStock is bool) &&
             (!('maxDiscount' in data) || (data.maxDiscount is number && data.maxDiscount >= 0)) &&
             (!('printMode' in data) || data.printMode in ['ALWAYS', 'NEVER', 'MANUAL']) &&
             (!('erpSyncFrequency' in data) || data.erpSyncFrequency in ['REALTIME', 'HOURLY', 'DAILY']) &&
             (!('operatingHours' in data) || (
               data.operatingHours is map &&
               (!('open' in data.operatingHours) || data.operatingHours.open is string) &&
               (!('close' in data.operatingHours) || data.operatingHours.close is string)
             )) &&
             (!('happyHour' in data) || (
               data.happyHour is map &&
               (!('enabled' in data.happyHour) || data.happyHour.enabled is bool) &&
               (!('start' in data.happyHour) || data.happyHour.start is string) &&
               (!('end' in data.happyHour) || data.happyHour.end is string) &&
               (!('discount' in data.happyHour) || data.happyHour.discount is number)
             )) &&
             (!('whatsappBotEnabled' in data) || data.whatsappBotEnabled is bool) &&
             (!('whatsappBotWelcomeMessage' in data) || (data.whatsappBotWelcomeMessage is string && data.whatsappBotWelcomeMessage.size() < 1000)) &&
             (!('whatsappBotMenuUrl' in data) || (data.whatsappBotMenuUrl is string && data.whatsappBotMenuUrl.size() < 500)) &&
             (!('whatsappTemplates' in data) || (
               data.whatsappTemplates is map &&
               (!('orderReceived' in data.whatsappTemplates) || data.whatsappTemplates.orderReceived is string)
             )) &&
             (!('theme' in data) || (
               data.theme is map &&
               (!('primaryColor' in data.theme) || data.theme.primaryColor is string) &&
               (!('secondaryColor' in data.theme) || data.theme.secondaryColor is string) &&
               (!('backgroundColor' in data.theme) || data.theme.backgroundColor is string) &&
               (!('textColor' in data.theme) || data.theme.textColor is string) &&
               (!('logoUrl' in data.theme) || data.theme.logoUrl is string)
             )) &&
             (!('ifoodClientId' in data) || data.ifoodClientId is string) &&
             (!('ifoodClientSecret' in data) || data.ifoodClientSecret is string) &&
             (!('fiscalEnvironment' in data) || data.fiscalEnvironment in ['homologacao', 'producao']) &&
             (!('nfeIoCompanyId' in data) || data.nfeIoCompanyId is string) &&
             (!('cscId' in data) || data.cscId is string) &&
             (!('cscToken' in data) || data.cscToken is string) &&
             (!('certificateBase64' in data) || data.certificateBase64 is string) &&
             (!('certificatePassword' in data) || data.certificatePassword is string);
    }

    // Validação para Sessões de Caixa
    function isValidCashierSession(data) {
      return data.openedAt is timestamp &&
             data.openedBy is string &&
             data.openingBalance is number &&
             data.status in ['OPEN', 'CLOSED'];
    }

    // Validação para Usuários
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'manager', 'waiter', 'kitchen', 'user'] &&
             (!('maxDiscount' in data) || data.maxDiscount is number);
    }

    // ===============================================================
    // Regras de Acesso por Coleção
    // ===============================================================

    // Coleção de Usuários (Controle de Acesso)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && 
                    ((request.auth.uid == userId && request.resource.data.role == 'user') || isAdmin()) &&
                    isValidUser(request.resource.data);
      allow update: if isManager() && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'updatedAt', 'maxDiscount']) &&
                     request.resource.data.role in ['admin', 'manager', 'waiter', 'kitchen', 'user']);
    }

    // Produtos do Cardápio
    match /products/{productId} {
      allow read: if true; // Público para o cardápio digital
      allow create, update: if isManager() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Pedidos
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() || true) && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && isValidOrder(request.resource.data) && 
                    (isManager() || !('deleted' in request.resource.data) || request.resource.data.deleted == resource.data.deleted);
      allow delete: if isAdmin();
    }

    // Mesas
    match /tables/{tableId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidTable(request.resource.data);
      allow delete: if isAdmin();
    }

    // Garçons
    match /waiters/{waiterId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidWaiter(request.resource.data);
      allow delete: if isAdmin();
    }

    // Configurações Gerais (Públicas)
    match /settings/general {
      allow read: if true;
      allow write: if isManager();
    }

    // Configurações Privadas (Fiscais/Integrações)
    match /settings/private {
      allow read, write: if isManager();
    }

    match /settings/{settingsId} {
      allow read, write: if isManager();
    }

    // Sessões de Caixa (Turnos)
    match /cashier_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCashierSession(request.resource.data);
      allow update: if isAuthenticated() && isValidCashierSession(request.resource.data);
      allow delete: if isAdmin();
    }

    // E-mails Autorizados
    match /allowed_emails/{emailId} {
      allow read: if true; // Necessário para verificar antes do login
      allow write: if isAdmin();
    }
  }
}
