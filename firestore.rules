rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Fields: items, status, paymentStatus, subtotal, total, type, createdAt, updatedAt, ...
    //
    // Collection: products
    // Fields: name, price, category, available, cost, barcode, imageUrl, ...
    //
    // Collection: tables
    // Fields: number, status, capacity, currentOrderId
    //
    // Collection: waiters
    // Fields: name, phone, active
    //
    // Collection: settings
    // Fields: restaurantName, address, phone, serviceFee, ...
    //
    // Collection: cashier_sessions
    // Fields: openedAt, closedAt, openedBy, closedBy, openingBalance, closingBalancePhysical, closingBalanceSystem, status
    //
    // Collection: allowed_emails
    // Fields: email, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "gustavosadoque19@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isManager() {
      return isAuthenticated() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // --- Domain Validators ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.available is bool &&
             data.stock is number;
    }

    function isValidOrder(data) {
      return data.items is list &&
             data.status in ['OPEN', 'PREPARING', 'DELIVERING', 'FINISHED', 'CANCELLED'] &&
             data.subtotal is number &&
             data.total is number &&
             data.type in ['TABLE', 'DELIVERY'] &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp);
    }

    function isValidTable(data) {
      return data.number is number &&
             data.status in ['Livre', 'Ocupada', 'Aguardando Limpeza', 'Fechando Conta'];
    }

    function isValidWaiter(data) {
      return data.name is string && data.name.size() > 0;
    }

    function isValidSettings(data) {
      return data.restaurantName is string && data.restaurantName.size() > 0 &&
             data.serviceFee is number && data.serviceFee >= 0 &&
             data.blockSaleNoStock is bool &&
             data.maxDiscount is number &&
             data.printMode in ['ALWAYS', 'NEVER', 'MANUAL'] &&
             data.erpSyncFrequency in ['REALTIME', 'HOURLY', 'DAILY'];
    }

    function isValidCashierSession(data) {
      return data.openedAt is timestamp &&
             data.openedBy is string &&
             data.openingBalance is number &&
             data.status in ['OPEN', 'CLOSED'];
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'manager', 'waiter', 'kitchen', 'user'] &&
             (!('maxDiscount' in data) || data.maxDiscount is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users Collection (for roles)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && 
                    ((request.auth.uid == userId && request.resource.data.role == 'user') || isAdmin()) &&
                    isValidUser(request.resource.data);
      allow update: if isManager() && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'updatedAt', 'maxDiscount']) &&
                     request.resource.data.role in ['admin', 'manager', 'waiter', 'kitchen', 'user']);
    }

    // Products
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && isValidOrder(request.resource.data) && 
                    (isManager() || !('deleted' in request.resource.data) || request.resource.data.deleted == resource.data.deleted);
      allow delete: if isAdmin();
    }

    // Tables
    match /tables/{tableId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidTable(request.resource.data);
      allow delete: if isAdmin();
    }

    // Waiters
    match /waiters/{waiterId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidWaiter(request.resource.data);
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingsId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager() && isValidSettings(request.resource.data);
    }

    // Cashier Sessions
    match /cashier_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCashierSession(request.resource.data);
      allow update: if isAuthenticated() && isValidCashierSession(request.resource.data);
      allow delete: if isAdmin();
    }

    // Allowed Emails
    match /allowed_emails/{emailId} {
      allow read: if true; // Needed for registration check before login
      allow write: if isAdmin();
    }
  }
}
