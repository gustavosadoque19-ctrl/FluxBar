rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "gustavosadoque19@gmail.com" ||
        request.auth.uid == "r8jQb1VIXJRHY52V91GjRAsU8lu2" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isManager() {
      return isAdmin() || (isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager');
    }

    function isWaiter() {
      return isManager() || (isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'waiter');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow create: if isAuthenticated() && isOwner(userId);
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isManager();
    }

    match /orders_deleted/{orderId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }

    match /waiters/{waiterId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /tables/{tableId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /settings/general {
      allow read: if true;
      allow write: if isManager();
    }

    match /settings/private {
      allow read, write: if isAdmin();
    }

    match /allowed_emails/{emailId} {
      allow read: if true; // Needed for registration check
      allow write: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow create: if true; // Allow anyone to submit a survey
      allow read, update, delete: if isManager();
    }

    match /cashier_sessions/{sessionId} {
      allow read, write: if isManager();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

